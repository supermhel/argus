{
  "index_patterns": ["events-bank-*"],
  "_comment": "Same field mappings as events-common; isolated index with 400d ILM for PCI-DSS retention.",
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 1,
      "index.lifecycle.name": "events-400d-pci"
    },
    "mappings": {
      "dynamic": "false",
      "properties": {
        "time": { "type": "date", "format": "epoch_millis" },
        "class_uid": { "type": "integer" },
        "category_uid": { "type": "integer" },
        "activity_id": { "type": "integer" },
        "type_uid": { "type": "integer" },
        "severity_id": { "type": "integer" },
        "status": { "type": "keyword" },
        "message": { "type": "text" },
        "src_endpoint": { "properties": { "ip": { "type": "ip" }, "mac": { "type": "keyword" }, "hostname": { "type": "keyword" }, "port": { "type": "integer" }, "reputation": { "properties": { "score": { "type": "integer" }, "categories": { "type": "keyword" }, "source": { "type": "keyword" } } }, "location": { "properties": { "country": { "type": "keyword" }, "source": { "type": "keyword" } } } } },
        "dst_endpoint": { "properties": { "ip": { "type": "ip" }, "mac": { "type": "keyword" }, "hostname": { "type": "keyword" }, "port": { "type": "integer" } } },
        "actor": { "properties": { "user": { "properties": { "name": { "type": "keyword" }, "uid": { "type": "keyword" }, "domain": { "type": "keyword" } } } } },
        "siem": { "properties": { "sector": { "type": "keyword" }, "source_type": { "type": "keyword" }, "ingest_id": { "type": "keyword" }, "tenant": { "type": "keyword" }, "score": { "type": "integer" } } }
      }
    }
  }
}
