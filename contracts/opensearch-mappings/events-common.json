{
  "index_patterns": ["events-common-*"],
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 1,
      "index.lifecycle.name": "events-30d"
    },
    "mappings": {
      "dynamic": "false",
      "properties": {
        "time": { "type": "date", "format": "epoch_millis" },
        "class_uid": { "type": "integer" },
        "category_uid": { "type": "integer" },
        "activity_id": { "type": "integer" },
        "type_uid": { "type": "integer" },
        "severity_id": { "type": "integer" },
        "status": { "type": "keyword" },
        "message": { "type": "text" },
        "metadata": {
          "properties": {
            "version": { "type": "keyword" },
            "original_format": { "type": "keyword" },
            "product": { "properties": { "name": { "type": "keyword" }, "vendor_name": { "type": "keyword" } } }
          }
        },
        "src_endpoint": { "properties": { "ip": { "type": "ip" }, "mac": { "type": "keyword" }, "hostname": { "type": "keyword" }, "port": { "type": "integer" } } },
        "dst_endpoint": { "properties": { "ip": { "type": "ip" }, "mac": { "type": "keyword" }, "hostname": { "type": "keyword" }, "port": { "type": "integer" } } },
        "actor": { "properties": { "user": { "properties": { "name": { "type": "keyword" }, "uid": { "type": "keyword" }, "domain": { "type": "keyword" } } } } },
        "siem": {
          "properties": {
            "sector": { "type": "keyword" },
            "source_type": { "type": "keyword" },
            "ingest_id": { "type": "keyword" },
            "tenant": { "type": "keyword" },
            "score": { "type": "integer" }
          }
        }
      }
    }
  }
}
