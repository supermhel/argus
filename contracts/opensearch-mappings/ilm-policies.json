        "warm": { "min_age": "30d", "actions": { "forcemerge": { "max_num_segments": 1 } } },
        "cold": { "min_age": "90d", "actions": {} },
        "delete": { "min_age": "400d", "actions": { "delete": {} } }
      }
    },
    "alerts-365d": {
      "phases": {
        "hot": { "actions": { "rollover": { "max_age": "7d", "max_size": "10gb" } } },
