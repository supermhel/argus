# WS-7 dashboard nginx config.
# Serves the static single-file dashboard AND reverse-proxies a same-origin path
# to OpenSearch so the browser can fetch LIVE alerts without a cross-origin (CORS)
# request. The nginx container is on the compose network, so `opensearch` resolves.
#
# This file is a TEMPLATE (nginx:alpine's official envsubst-on-templates
# entrypoint hook renders /etc/nginx/templates/*.template -> conf.d/*.conf at
# container start, substituting only vars actually present in the container's
# environment -- nginx's own lowercase $host/$uri/$content_type are untouched).
# v0.4 Track S1: ${FENGARDE_API_KEY} lets nginx inject the shared secret on the
# triage proxy so the browser never holds the key.
server {
    listen 80;
    server_name _;
    root /usr/share/nginx/html;
    index index.html;

    # v0.4 Track S2: opt-in basic-auth. Default "off" (main compose file) --
    # the override compose (docker-compose.auth.yml) sets DASHBOARD_AUTH_REALM
    # to a quoted realm string and mounts a real htpasswd over the placeholder
    # baked into the image, so this stays a no-op until explicitly enabled.
    auth_basic ${DASHBOARD_AUTH_REALM};
    auth_basic_user_file /etc/nginx/dashboard.htpasswd;

    location / {
        try_files $uri $uri/ =404;
    }

    # DX4: same-origin live-alerts endpoint. The front end fetches /api/alerts and
    # nginx proxies it to OpenSearch's alerts-* search. The upstream is resolved at
    # request time via Docker's embedded DNS (127.0.0.11) so nginx still starts even
    # if OpenSearch is not yet up.
    location = /api/alerts {
        # Use a variable so nginx defers DNS resolution until request time (Docker's
        # embedded DNS 127.0.0.11). Without the variable, nginx resolves `opensearch`
        # at startup and fails if the container isn't up yet.
        resolver 127.0.0.11 ipv6=off valid=30s;
        set $opensearch "http://opensearch:9200";

        # POST a JSON query body — the only reliable way to pass query params when
        # using a variable upstream. With a variable, nginx ignores any query string
        # appended to proxy_pass, so URI-search params are silently dropped.
        # This query: newest 50 real rule alerts (excludes ai.results which lack rule_title).
        proxy_pass $opensearch/alerts-*/_search;
        proxy_method POST;
        proxy_set_header Content-Type "application/json";
        proxy_set_header Host $host;
        proxy_set_body '{"size":50,"sort":[{"time":"desc"}],"query":{"exists":{"field":"rule_title"}}}';

        # Keep the dashboard resilient: on 5xx / timeout return an empty hits array so
        # the front end falls back to mock data. NOTE: a 404 from OpenSearch (index not
        # yet created on a fresh stack) is NOT intercepted here — it passes through as
        # 404, and the JS `r.ok` check (false for 404) correctly falls back to mock data.
        proxy_connect_timeout 3s;
        proxy_read_timeout 5s;
        proxy_intercept_errors on;
        error_page 502 503 504 = @alerts_unavailable;
    }

    location @alerts_unavailable {
        default_type application/json;
        return 200 '{"hits":{"hits":[]},"_fengarde_proxy":"opensearch_unavailable"}';
    }

    # M3: same-origin proxy for the RBAC session API (/auth/login, /auth/logout,
    # /auth/me on ws3-indexer's triage_api.py). Forwards Cookie/Set-Cookie
    # unmodified (nginx's default proxy behavior) so the HttpOnly session
    # cookie round-trips exactly as the backend set it. Also forwards
    # X-Api-Key (empty/no-op when unset) -- needed so GET /auth/me still
    # reaches ws3-indexer's route dispatch (-> a clean 404, meaning "RBAC is
    # off, no login system here") rather than being blocked earlier by the
    # API-key check in the (unusual but valid) deployment combo of
    # FENGARDE_API_KEY set with RBAC off; the front end tells "not logged in"
    # (401) apart from "no login system at all" (404) by this exact status.
    location /api/auth/ {
        resolver 127.0.0.11 ipv6=off valid=30s;
        set $ws3_auth "http://ws3-indexer:8013";
        rewrite ^/api/auth/(.*)$ /auth/$1 break;
        proxy_pass $ws3_auth;
        proxy_set_header Host $host;
        proxy_set_header Content-Type $content_type;
        proxy_set_header X-Api-Key "${FENGARDE_API_KEY}";
        proxy_connect_timeout 3s;
        proxy_read_timeout 5s;
    }

    # C1 (v0.3): same-origin proxy for the triage API (ws3-indexer's
    # triage_api.py, a separate port from the bus/health runner). Unlike the
    # /api/alerts proxy above, this forwards the client's real method/body
    # unmodified (GET for reads, POST {status,note} for updates) -- the
    # front end already handles a proxy/backend failure gracefully (falls
    # back to a local default / keeps the optimistic UI value), so no fake-
    # success fallback is needed here the way it is for the read-only
    # alerts feed.
    location /api/triage/ {
        resolver 127.0.0.11 ipv6=off valid=30s;
        set $ws3_triage "http://ws3-indexer:8013";
        rewrite ^/api/triage/(.*)$ /$1 break;
        proxy_pass $ws3_triage;
        proxy_set_header Host $host;
        proxy_set_header Content-Type $content_type;
        # v0.4 Track S1: forward the shared API key so the browser never holds
        # it. Empty when FENGARDE_API_KEY is unset (auth disabled, unchanged
        # behavior) -- ws3-indexer's authz check treats an empty header the
        # same as a missing one.
        proxy_set_header X-Api-Key "${FENGARDE_API_KEY}";
        proxy_connect_timeout 3s;
        proxy_read_timeout 5s;
    }
}
